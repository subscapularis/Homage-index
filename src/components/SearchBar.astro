---
// src/components/SearchBar.astro
---

<div class="search-wrapper">
  <input 
    type="text" 
    class="search-input t-label" 
    placeholder="Search homages..." 
    aria-label="Search homages"
  />
  
  <button class="search-button" aria-label="Submit search">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
  </button>
</div>

<style>
.search-wrapper {
  display: flex;
  align-items: center;
  background: transparent;
  border: 0.5px solid #e0ddd6;
  border-radius: 999px;
  height: 40px;
  padding: 2px 2px 2px 16px;
  width: 100%;
  max-width: 480px;
  transition: border-color var(--transition);
}

.search-wrapper:focus-within {
  border-color: #1c1b1a;
}

.search-input {
  flex: 1;
  border: none;
  background: transparent;
  outline: none;
  font-size: 0.85rem;
  color: var(--color-ink);
  min-width: 0; /* Prevents input from breaking flexbox */
}

.search-input::placeholder {
  color: var(--color-ink-faint);
  font-family: var(--font-body); /* Matching the t-label styling */
  letter-spacing: 0.05em;
  text-transform: uppercase;
  font-size: 0.75rem;
}

.search-button {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-ink);
  color: #ffffff;
  border: none;
  border-radius: 999px;
  height: 100%;
  padding: 0 16px;
  cursor: pointer;
  transition: opacity var(--transition);
}

.search-button:hover {
  opacity: 0.9;
}
</style>
