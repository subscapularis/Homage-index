---
// WatchCard.astro
// variant: 'luxury' | 'homage'
// comparisonUrl: optional link to the full comparison page (used on homepage simplified cards)
import { Image } from 'astro:assets';

const { watch, variant, simplified = false, comparisonUrl } = Astro.props;
const isLuxury = variant === 'luxury';
---

<div class={`watch-card watch-card--${variant} ${simplified ? 'watch-card--simplified' : ''}`}>
  <!-- Image — hero of the card -->
  <div class="card-image">
    {watch.image
      ? typeof watch.image === 'string' ? (
          <img
            src={watch.image}
            alt={watch.imageAlt}
            loading="lazy"
            decoding="async"
            width="600"
            height="600"
          />
        ) : (
          <Image 
            src={watch.image} 
            alt={watch.imageAlt} 
            width={600} 
            height={600} 
          />
        )
      : <div class="card-image-placeholder" aria-hidden="true">
          <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="placeholder-svg">
            <circle cx="60" cy="60" r="46" stroke={isLuxury ? '#c8b89a' : '#3a3a3a'} stroke-width="1"/>
            <circle cx="60" cy="60" r="40" fill={isLuxury ? '#1a1a1a' : '#0d0d0d'} stroke={isLuxury ? '#333' : '#222'} stroke-width="0.5"/>
            <circle cx="60" cy="60" r="34" stroke={isLuxury ? '#444' : '#1a1a1a'} stroke-width="0.5"/>
            <rect x="57" y="14" width="6" height="12" rx="1" fill={isLuxury ? '#c8b89a' : '#555'}/>
            <rect x="57" y="94" width="6" height="12" rx="1" fill={isLuxury ? '#c8b89a' : '#555'}/>
            <rect x="14" y="57" width="12" height="6" rx="1" fill={isLuxury ? '#c8b89a' : '#555'}/>
            <rect x="94" y="57" width="12" height="6" rx="1" fill={isLuxury ? '#c8b89a' : '#555'}/>
            <circle cx="60" cy="60" r="3" fill={isLuxury ? '#c8b89a' : '#888'}/>
            <line x1="60" y1="57" x2="60" y2="32" stroke={isLuxury ? '#f0ece4' : '#bbb'} stroke-width="1.5" stroke-linecap="round"/>
            <line x1="60" y1="57" x2="78" y2="67" stroke={isLuxury ? '#f0ece4' : '#bbb'} stroke-width="1.2" stroke-linecap="round"/>
            <rect x="56" y="0" width="8" height="14" rx="2" fill={isLuxury ? '#b0a898' : '#222'} stroke={isLuxury ? '#8a8070' : '#111'} stroke-width="0.5"/>
            <rect x="56" y="106" width="8" height="14" rx="2" fill={isLuxury ? '#b0a898' : '#222'} stroke={isLuxury ? '#8a8070' : '#111'} stroke-width="0.5"/>
          </svg>
        </div>
    }
    <span class={`card-tag t-label card-tag--${variant}`}>
      {isLuxury ? 'Original' : 'Homage'}
    </span>

    {/* Similarity score on top right of the card within a circle */}
    {simplified && watch.matchScore && (
      <div class="card-score-circle" aria-label={`Similarity Score: ${watch.matchScore}%`}>
        <span class="score-num">{watch.matchScore}</span>
      </div>
    )}
  </div>

  <!-- Identity + price -->
  <div class="card-body">
    <div class="card-identity">
      <p class={`card-brand t-label brand--${variant}`}>{watch.brand}</p>
      <h3 class={`card-model model--${variant}`}>{watch.model}</h3>
      {!simplified && <p class={`card-reference t-label reference--${variant}`}>{watch.reference}</p>}
    </div>
    <div class="card-price-block">
      <p class={`card-price price--${variant}`}>
        ${watch.price.toLocaleString('en-US')}
      </p>
      <p class={`card-price-label t-label pricelabel--${variant}`}>
        {isLuxury ? 'Retail price' : 'Current price'}
      </p>
    </div>
  </div>

  <!-- Specs row -->
  {!simplified && (
    <>
      <div class={`card-divider divider--${variant}`}></div>
      <dl class="specs-row">
        {Object.entries(watch.specs).map(([key, val]) => (
          <div class="spec-item">
            <dd class={`spec-val t-display specval--${variant}`}>{val}</dd>
            <dt class={`spec-key t-label speckey--${variant}`}>{key.replace(/([A-Z])/g, ' $1').toLowerCase()}</dt>
          </div>
        ))}
      </dl>
    </>
  )}

  <!-- CTA -->
  {!simplified && <div class={`card-divider divider--${variant}`}></div>}
  <div class="card-cta">
    <a
      href={watch.buyUrl}
      target="_blank"
      rel="noopener noreferrer nofollow"
      class={`cta-btn t-label cta--${variant}`}
    >
      {watch.buyLabel}
    </a>
  </div>

  {/* Full Comparison link inside simplified cards */}
  {simplified && comparisonUrl && (
    <div class="card-comparison">
      <a href={comparisonUrl} class="comparison-link t-label" data-astro-prefetch>
        Full Comparison & Analysis →
      </a>
    </div>
  )}
</div>

<style>
/* ── Shared card shell ── */
.watch-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
  width: 100%;
}

.watch-card--luxury {
  background: #ffffff;
  border: 0.5px solid #e0ddd6;
}

.watch-card--homage {
  background: var(--color-dark-bg);
  border: 0.5px solid var(--color-dark-border);
}

/* ── Image area ── */
.card-image {
  position: relative;
  width: 100%;
  aspect-ratio: 4 / 3;
  overflow: hidden;
}

.watch-card--luxury .card-image { background: var(--color-paper); }
.watch-card--homage .card-image { background: #141414; }

.card-image img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 1rem;
}

.card-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-svg {
  width: 68%;
  height: 68%;
}

/* Tag badge overlaid on image */
.card-tag {
  position: absolute;
  top: 0.6rem;
  left: 0.6rem;
  padding: 4px 11px;
  border-radius: var(--radius-sm);
  font-size: 11px;
  z-index: 5;
}

.card-tag--luxury {
  background: rgba(245,243,239,0.9);
  color: #8a7e6e;
  border: 0.5px solid #ddd8cf;
}

.card-tag--homage {
  background: rgba(26,26,26,0.9);
  color: #6a6a6a;
  border: 0.5px solid #333;
}

/* Similarity score circle on top right */
.card-score-circle {
  position: absolute;
  top: 0.6rem;
  right: 0.6rem;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: var(--color-gold);
  color: var(--color-ink);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.25);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
  z-index: 10;
}

.card-score-circle .score-num {
  font-family: var(--font-display);
  font-size: 17px;
  font-weight: 400;
  font-variant-numeric: lining-nums;
  line-height: 1;
}

/* ── Body ── */
.card-body {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0.75rem 1rem 0.6rem;
  gap: 0.75rem;
}

.card-identity { flex: 1; }

.card-brand { margin-bottom: 3px; }
.brand--luxury { color: var(--color-ink-faint); }
.brand--homage { color: #787878; }

.card-model {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 300;
  font-variant-numeric: lining-nums;
  line-height: 1.2;
  margin-bottom: 2px;
}
.model--luxury { color: var(--color-ink); }
.model--homage { color: var(--color-dark-text); }

.card-reference { }
.reference--luxury { color: var(--color-ink-faint); }
.reference--homage { color: var(--color-dark-muted); }

.card-price-block { text-align: right; flex-shrink: 0; }

.card-price {
  font-family: var(--font-display);
  font-size: 1.65rem;
  font-weight: 300;
  font-style: normal;
  font-variant-numeric: lining-nums;
  line-height: 1;
  margin-bottom: 3px;
}
.price--luxury { color: var(--color-ink); }
.price--homage { color: var(--color-gold); }

.card-price-label { }
.pricelabel--luxury { color: var(--color-ink-faint); }
.pricelabel--homage { color: #787878; }

/* ── Divider ── */
.card-divider { height: 0.5px; margin: 0 1rem; }
.divider--luxury { background: #e0ddd6; }
.divider--homage { background: var(--color-dark-faint); }

/* ── Specs ── */
.specs-row {
  display: flex;
  padding: 0.5rem 1rem;
  list-style: none;
}

.spec-item {
  flex: 1;
  text-align: center;
}

.spec-item + .spec-item {
  border-left: 0.5px solid;
}

.watch-card--luxury .spec-item + .spec-item { border-color: #e0ddd6; }
.watch-card--homage .spec-item + .spec-item { border-color: var(--color-dark-faint); }

.spec-val {
  font-family: var(--font-display);
  font-size: 0.95rem;
  font-weight: 300;
  font-variant-numeric: lining-nums;
  line-height: 1.3;
}
.specval--luxury { color: var(--color-ink); }
.specval--homage { color: #d4c5a9; }

.spec-key {
  font-size: 9px;
  margin-top: 2px;
}
.speckey--luxury { color: var(--color-ink-faint); }
.speckey--homage { color: #787878; }

/* ── CTA ── */
.card-cta { padding: 0.6rem 1rem 1rem; }

.cta-btn {
  display: block;
  text-align: center;
  padding: 11px 0.75rem;
  border-radius: var(--radius-sm);
  transition: opacity var(--transition);
  font-size: 11px;
  letter-spacing: 0.14em;
}

.cta-btn:hover { opacity: 0.85; }

.cta--luxury {
  background: var(--color-ink);
  color: #ffffff;
}

.cta--homage {
  background: var(--color-gold);
  color: var(--color-ink);
}

/* ── Simplified Card Styles for Homepage Grid ── */
.watch-card--simplified {
  display: flex;
  flex-direction: column;
  height: 100%;
  justify-content: space-between;
}

.watch-card--simplified .card-body {
  flex-grow: 1;
  display: flex;
  justify-content: space-between;
  align-items: stretch;
  padding: 0.75rem 0.85rem 0.6rem;
}

.watch-card--simplified .card-identity {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  flex: 1;
}

.watch-card--simplified .card-brand {
  margin-bottom: 1px;
}

.watch-card--simplified .card-model {
  line-height: 1.25;
  margin-top: 2px;
}

.watch-card--simplified .card-price-block {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-end;
}

.watch-card--simplified .card-cta {
  padding: 0.4rem 0.85rem 0.5rem;
}

/* ── In-card comparison link ── */
.card-comparison {
  padding: 0 0.85rem 0.85rem;
  margin-top: 0;
}

.card-comparison .comparison-link {
  display: block;
  text-align: center;
  padding: 10px 0.5rem;
  border-radius: var(--radius-sm);
  background: transparent;
  border: 0.5px solid #444;
  color: #999;
  font-size: 11px;
  letter-spacing: 0.12em;
  transition: all var(--transition);
  text-decoration: none;
}

.card-comparison .comparison-link:hover {
  border-color: var(--color-gold);
  color: var(--color-gold);
}
</style>
