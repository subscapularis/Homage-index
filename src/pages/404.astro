---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found — Homage Index">
  <div class="container not-found">
    <p class="t-label eyebrow">404</p>
    <h1 class="nf-title">This pair doesn't exist.</h1>
    <p class="nf-sub">Maybe it hasn't been added yet.</p>
    <a href="/" class="t-label nf-link">← Back to all pairs</a>
  </div>
</BaseLayout>

<style>
.not-found {
  padding: 5rem 0;
  max-width: 400px;
}
.eyebrow { color: var(--color-ink-faint); margin-bottom: 0.75rem; }
.nf-title {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 300;
  font-style: normal;
  font-variant-numeric: lining-nums;
  color: var(--color-ink);
  margin-bottom: 0.5rem;
}
.nf-sub { color: var(--color-ink-muted); margin-bottom: 1.5rem; }
.nf-link { color: var(--color-ink-muted); }
.nf-link:hover { color: var(--color-ink); }
</style>
