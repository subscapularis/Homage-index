---
import BaseLayout from '../layouts/BaseLayout.astro';
import WatchCard from '../components/WatchCard.astro';
import { getCollection } from 'astro:content';

const pairs = await getCollection('pairs');
---

<BaseLayout
  title="Homage Index — Luxury Watch Homages, Ranked"
  description="Find the most visually accurate homage for every luxury watch. Side-by-side comparisons, similarity scores, and direct links to buy."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="t-label hero-eyebrow">The definitive resource</p>
      <h1 class="hero-title">Luxury watches.<br/>Accessible prices.</h1>
      <p class="hero-sub">
        Every pair ranked by visual similarity. Every homage linked directly to buy.
      </p>
    </div>
  </section>

  <!-- Filter bar -->
  <section class="filter-bar">
    <div class="container filter-inner">
      <span class="t-label filter-label">Browse by</span>
      <div class="filter-chips" role="list">
        <span class="filter-chip filter-chip--active t-label" role="listitem">All</span>
        <span class="filter-chip t-label" role="listitem">Dive</span>
        <span class="filter-chip t-label" role="listitem">Dress Sports</span>
        <span class="filter-chip t-label" role="listitem">Pilot</span>
        <span class="filter-chip t-label" role="listitem">Dress</span>
      </div>
      <span class="t-label pair-count">{pairs.length} pairs</span>
    </div>
  </section>

  <!-- Pair directory -->
  <section class="directory">
    <div class="container">
      {pairs.map((pair) => (
        <article class="luxury-group" data-category={pair.data.category} aria-label={`Homages for ${pair.data.luxury.brand} ${pair.data.luxury.model}`}>
          <!-- Luxury watch heading exactly as user requested -->
          <h2 class="luxury-title">
            {pair.data.luxury.brand} {pair.data.luxury.model} {pair.data.luxury.reference} {pair.data.luxury.imageAlt.toLowerCase().includes('black') ? 'black dial' : 'blue dial'}
          </h2>
          
          <!-- Grid of homages: 3 columns on desktop to make them bigger and reveal all gorgeous details -->
          <div class="shrunk-grid">
            {pair.data.homages.map((homage) => (
              <WatchCard watch={homage} variant="homage" simplified={true} comparisonUrl={`/${pair.data.seo.slug}`} />
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  // Filter chips interaction
  const chips = document.querySelectorAll('.filter-chip');
  const groups = document.querySelectorAll('.luxury-group');

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      // Remove active class from all chips
      chips.forEach(c => c.classList.remove('filter-chip--active'));
      // Add active class to clicked chip
      chip.classList.add('filter-chip--active');

      const category = chip.textContent.trim().toLowerCase();

      groups.forEach(group => {
        const groupCategory = group.getAttribute('data-category').trim().toLowerCase();
        
        // Simple matching logic: "all" matches everything, else check sub-string
        if (category === 'all' || groupCategory.includes(category)) {
          (group as HTMLElement).style.display = 'block';
        } else {
          (group as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
/* ── Hero ── */
.hero {
  padding: 1.75rem 0 2rem;
  border-bottom: 0.5px solid #e0ddd6;
}

.hero-eyebrow {
  color: var(--color-ink-faint);
  margin-bottom: 0.75rem;
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 300;
  font-style: normal;
  font-variant-numeric: lining-nums;
  line-height: 1.1;
  color: var(--color-ink);
  margin-bottom: 1rem;
}

.hero-sub {
  font-size: 0.9rem;
  color: var(--color-ink-muted);
  max-width: 460px;
  line-height: 1.7;
}

/* ── Filter bar ── */
.filter-bar {
  border-bottom: 0.5px solid #e0ddd6;
  padding: 0.85rem 0;
  position: sticky;
  top: 49px;
  background: #faf9f6;
  z-index: 90;
}

.filter-inner {
  display: flex;
  align-items: center;
  gap: 1rem;
  overflow-x: auto;
  scrollbar-width: none;
}

.filter-inner::-webkit-scrollbar { display: none; }

.filter-label { color: var(--color-ink-faint); flex-shrink: 0; }

.filter-chips { display: flex; gap: 0.5rem; flex-shrink: 0; }

.filter-chip {
  padding: 4px 12px;
  border-radius: 20px;
  border: 0.5px solid #e0ddd6;
  color: var(--color-ink-muted);
  cursor: pointer;
  white-space: nowrap;
  transition: all var(--transition);
}

.filter-chip:hover {
  border-color: var(--color-ink-faint);
  color: var(--color-ink);
}

.filter-chip--active {
  background: var(--color-ink);
  color: #fff;
  border-color: var(--color-ink);
}

.pair-count {
  color: var(--color-ink-faint);
  margin-left: auto;
  flex-shrink: 0;
}

/* ── Directory ── */
.directory {
  padding: 3rem 0;
}

.luxury-group {
  margin-bottom: 4.5rem;
}

.luxury-title {
  font-family: var(--font-display);
  font-size: clamp(1.3rem, 3.5vw, 1.8rem);
  font-weight: 300;
  font-variant-numeric: lining-nums;
  color: var(--color-ink);
  margin-bottom: 1.5rem;
  border-bottom: 0.5px solid #e0ddd6;
  padding-bottom: 0.5rem;
  letter-spacing: 0.02em;
}

/* Homepage Grid: 3 columns on desktop to make cards bigger and visually legible */
.shrunk-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  margin-bottom: 1.5rem;
  align-items: stretch;
}

@media (min-width: 540px) {
  .shrunk-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 768px) {
  .shrunk-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* ── Homepage WatchCard Styling Overrides ── */
.shrunk-grid :global(.watch-card) {
  border-radius: var(--radius-md);
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  display: flex;
  flex-direction: column;
  height: 100%;
}

.shrunk-grid :global(.watch-card:hover) {
  transform: translateY(-3px);
  border-color: var(--color-gold);
  box-shadow: 0 4px 15px rgba(200, 184, 154, 0.15);
}

.shrunk-grid :global(.card-image) {
  aspect-ratio: 4 / 3;
  width: 100%;
}

.shrunk-grid :global(.card-image img) {
  padding: 1rem;
}

.shrunk-grid :global(.card-body) {
  flex-grow: 1;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: stretch;
  padding: 0.85rem 1rem 0.65rem;
  gap: 0.5rem;
}

.shrunk-grid :global(.card-identity) {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  flex: 1;
  min-height: 48px; /* standard height to align wrapping watch titles */
}

.shrunk-grid :global(.card-brand) {
  font-size: 11px;
  margin-bottom: 2px;
}

.shrunk-grid :global(.card-model) {
  font-size: 1.2rem;
  line-height: 1.25;
  margin-top: 2px;
}

.shrunk-grid :global(.card-price-block) {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-end;
  text-align: right;
  flex-shrink: 0;
}

.shrunk-grid :global(.card-price) {
  font-size: 1.45rem;
  line-height: 1;
}

.shrunk-grid :global(.card-price-label) {
  font-size: 9px;
  margin-top: 3px;
}

.shrunk-grid :global(.card-cta) {
  padding: 0.4rem 1rem 1rem;
  margin-top: auto;
}

.shrunk-grid :global(.cta-btn) {
  padding: 10px 0.5rem;
  font-size: 11px;
  letter-spacing: 0.12em;
}

.shrunk-grid :global(.card-comparison) {
  margin-top: auto;
}
</style>
