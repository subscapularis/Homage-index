---
import '../styles/global.css';
import { Font } from 'astro:assets';

const {
  title = 'Homage Index — Luxury Watch Homages, Ranked',
  description = 'Find the most visually accurate homage for every luxury watch. Side-by-side comparisons, similarity scores, and direct links to buy.',
  canonicalUrl,
  ogImage = '/og-default.jpg',
} = Astro.props;

const canonical = canonicalUrl ?? Astro.url.href;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#faf9f6" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Structured data -->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Homage Index",
      "url": "https://homageindex.com",
      "description": "Luxury watch homage comparisons with similarity scores",
    })}
  </script>

  <!-- Preconnect for fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Josefin+Sans:wght@300;400&display=swap" rel="stylesheet" />
  <Font cssVariable="--font-display" preload />
  <Font cssVariable="--font-body" preload />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="wordmark" aria-label="Homage Index home">
        <span class="wordmark-sub t-label">Est. 2025</span>
        <span class="wordmark-title">Homage Index</span>
      </a>

      <nav class="site-nav" aria-label="Main navigation">
        <a href="/" class="nav-link t-label">All Pairs</a>
        <a href="/about" class="nav-link t-label">About</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <script>
    // Scroll-aware header
    const header = document.querySelector('.site-header');
    const onScroll = () => {
      header?.classList.toggle('scrolled', window.scrollY > 10);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Mark active nav link
    const navLinks = document.querySelectorAll('.nav-link');
    navLinks.forEach(link => {
      if ((link as HTMLAnchorElement).pathname === location.pathname) {
        link.setAttribute('aria-current', 'page');
      }
    });
  </script>

  <footer class="site-footer">
    <div class="container footer-inner">
      <p class="t-label footer-note">
        Homage Index contains affiliate links. We may earn a small commission if you purchase through our links, at no extra cost to you. All similarity scores are editorial judgments.
      </p>
      <p class="t-label footer-copy">© {new Date().getFullYear()} Homage Index</p>
    </div>
  </footer>
</body>
</html>

<style>
/* ── Keyframes ── */
@keyframes header-drop {
  from { transform: translateY(-100%); opacity: 0; }
  to   { transform: translateY(0);     opacity: 1; }
}

@keyframes fade-up {
  from { transform: translateY(6px); opacity: 0; }
  to   { transform: translateY(0);   opacity: 1; }
}

@keyframes shimmer {
  0%   { background-position: -200% center; }
  100% { background-position:  200% center; }
}

@keyframes nav-pop {
  0%   { transform: translateY(0) scale(1); }
  40%  { transform: translateY(-3px) scale(1.04); }
  100% { transform: translateY(0) scale(1); }
}

/* ── Site header ── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(250, 249, 246, 0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 0.5px solid #e0ddd6;
  transition: box-shadow 0.3s ease, background 0.3s ease;
  animation: header-drop 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.site-header.scrolled {
  box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
  background: rgba(250, 249, 246, 0.96);
}

/* gold accent line that slides in on scroll */
.site-header::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--color-gold), transparent);
  transition: width 0.6s ease;
}

.site-header.scrolled::after {
  width: 100%;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 0.65rem;
  padding-bottom: 0.65rem;
}

/* ── Wordmark ── */
.wordmark {
  display: flex;
  flex-direction: column;
  gap: 2px;
  text-decoration: none;
  position: relative;
  animation: fade-up 0.6s 0.15s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.wordmark-sub {
  color: var(--color-ink-faint);
  transition: color 0.2s ease;
}

.wordmark-title {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 300;
  font-style: normal;
  font-variant-numeric: lining-nums;
  color: var(--color-ink);
  line-height: 1;
  transition: letter-spacing 0.35s ease;
  background-size: 200% auto;
}

/* shimmer sweep on hover */
.wordmark:hover .wordmark-title {
  letter-spacing: 0.04em;
  background: linear-gradient(
    90deg,
    var(--color-ink) 0%,
    var(--color-gold-dark) 40%,
    var(--color-ink) 60%,
    var(--color-ink) 100%
  );
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 0.8s linear forwards;
}

.wordmark:not(:hover) .wordmark-title {
  -webkit-text-fill-color: var(--color-ink);
}

.wordmark:hover .wordmark-sub {
  color: var(--color-gold-dark);
}

.wordmark-tag {
  color: var(--color-ink-faint);
  display: none;
}

@media (min-width: 640px) {
  .wordmark-tag { display: block; }
}

/* ── Nav ── */
.site-nav {
  display: flex;
  gap: 1.5rem;
  align-items: center;
}

/* staggered entrance for each nav link */
.nav-link {
  color: var(--color-ink-muted);
  position: relative;
  padding-bottom: 2px;
  transition: color 0.2s ease, transform 0.2s ease;
  opacity: 0;
  animation: fade-up 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.nav-link:nth-child(1) { animation-delay: 0.3s; }
.nav-link:nth-child(2) { animation-delay: 0.42s; }

/* animated underline */
.nav-link::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 50%;
  width: 0;
  height: 1px;
  background: var(--color-gold-dark);
  transition: width 0.25s ease, left 0.25s ease;
}

.nav-link:hover {
  color: var(--color-ink);
  animation: nav-pop 0.35s ease forwards;
}

/* underline expands from center */
.nav-link:hover::after {
  width: 100%;
  left: 0;
}

/* active state */
.nav-link[aria-current="page"] {
  color: var(--color-ink);
  opacity: 1;
}

.nav-link[aria-current="page"]::after {
  width: 100%;
  left: 0;
  background: var(--color-gold);
}

/* ── Footer ── */
.site-footer {
  border-top: 0.5px solid #e0ddd6;
  margin-top: 4rem;
  padding: 2rem 0;
}

.footer-inner {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  align-items: center;
  text-align: center;
}

.footer-note {
  color: var(--color-ink-faint);
  max-width: 600px;
  line-height: 1.7;
}

.footer-copy {
  color: var(--color-ink-faint);
}
</style>
